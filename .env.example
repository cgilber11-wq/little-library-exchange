# Generate a random string for NextAuth (e.g. run: openssl rand -base64 32)
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Canonical site URL for QR codes (optional locally; required in production)
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# Local Postgres via embedded server (npm run db:up):
DATABASE_URL="postgresql://lle:lle@127.0.0.1:54329/little_library_exchange?schema=public"
# Or Docker Compose (port 5432):
# DATABASE_URL="postgresql://lle:lle@localhost:5432/little_library_exchange?schema=public"
# Production (Neon / Vercel Postgres):
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"

# Library profile photos — local disk when unset; set for production (Vercel Blob).
# BLOB_READ_WRITE_TOKEN=
