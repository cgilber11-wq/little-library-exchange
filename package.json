{
  "name": "little-library-exchange",
  "version": "0.1.0-alpha.1",
  "private": true,
  "scripts": {
    "dev": "WATCHPACK_POLLING=true next dev",
    "dev:clean": "rm -rf .next && WATCHPACK_POLLING=true next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:up": "node scripts/local-pg.js start",
    "db:down": "node scripts/local-pg.js stop",
    "db:docker:up": "docker compose up -d db",
    "db:docker:down": "docker compose down",
    "db:status": "node scripts/local-pg.js status",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node scripts/seed-dev-data.js",
    "db:seed:me": "node scripts/seed-my-account.js",
    "db:backfill-slugs": "node scripts/backfill-library-slugs.js",
    "db:reset:local": "prisma migrate reset --force",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@vercel/blob": "^2.6.1",
    "bcryptjs": "^2.4.3",
    "next": "^14.2.0",
    "next-auth": "^4.24.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "embedded-postgres": "^18.4.0-beta.17",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "prisma": "^5.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
